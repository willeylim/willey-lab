{
  "_comment": "Maps file patterns to layers and their applicable standards files. PRECEDENCE: CS-SCOPE (components.md) is applied FIRST as a gating filter — vendor/generated/third-party files it excludes are not routed to any layer or rule. TypeScript rules (typescript.md) apply to ALL .ts/.tsx files, matching the PreToolUse hook; a .tsx file additionally matches the ui layer.",
  "file-patterns": {
    "backend": [
      "*.service.ts", "*.controller.ts", "*.module.ts", "*.guard.ts",
      "*.pipe.ts", "*.decorator.ts", "*.go", "*.rs", "*.php", "*.py",
      "app/Http/**", "app/Models/**", "app/Providers/**"
    ],
    "frontend": [
      "**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"
    ],
    "ui": [
      "*.css", "*.scss", "*.module.css", "*.module.scss",
      "*.tsx", "*.jsx", "*.vue", "*.svelte"
    ]
  },
  "layer-standards": {
    "backend": [
      "functions.md", "naming.md", "error-handling.md",
      "objects-and-data.md", "formatting.md", "code-principles.md"
    ],
    "frontend": [
      "functions.md", "naming.md", "error-handling.md",
      "objects-and-data.md", "formatting.md", "code-principles.md",
      "components.md", "typescript.md"
    ],
    "ui": [
      "ui-ux.md"
    ]
  },
  "layer-skills": {
    "backend": ["nestjs", "go", "rust", "laravel", "python", "php"],
    "frontend": ["nextjs", "react", "typescript"],
    "ui": ["ui"]
  }
}
